<Config>

	<append xpath="/nav_object_classes">

		<nav_object_class name="ZombieINC_EnemyDot" extends="zombie">
					
			<map_settings>
				<property name="sprite_name" value="ui_game_symbol_enemy_dot"/>
				<property name="color" value="255,0,0,255"/>
				<property name="has_pulse" value="true"/>
			</map_settings>

			<compass_settings>
				<property name="sprite_name" value="ui_game_symbol_enemy_dot"/>
				<property name="color" value="255,0,0,255"/>
				<property name="has_pulse" value="true"/>
				<property name="icon_clamped" value="true" />
			</compass_settings>
		</nav_object_class>
		
		
		<nav_object_class name="ZombieINC_supply">
		

			<map_settings>
				<property name="sprite_name" value="ui_game_symbol_twitch_drop"/>
				<property name="min_distance" value="0"/>
				<property name="max_distance" value="-1"/>
				<property name="color" value="10,200,10,255"/>
				<property name="has_pulse" value="true"/>
			</map_settings>

			<compass_settings>
				<property name="sprite_name" value="ui_game_symbol_twitch_drop"/>
				<property name="min_distance" value="0"/>
				<property name="max_distance" value="500"/>
				<property name="max_scale_distance" value="1024"/>
				<property name="color" value="10,200,10,255"/>
				<property name="has_pulse" value="true"/>
				<property name="icon_clamped" value="false" />
			</compass_settings>

			<onscreen_settings>
				<property name="sprite_name" value="ui_game_symbol_twitch_drop"/>
				<property name="min_distance" value="0"/>
				<property name="max_distance" value="500"/>
				<property name="color" value="10,200,10,255"/>
				<property name="has_pulse" value="true"/>
				<property name="text_type" value="SpawnName"/>
			</onscreen_settings>
		</nav_object_class>

		<nav_object_class name="ZombieINC_supply_other">
		
		
			<map_settings>
				<property name="sprite_name" value="ui_game_symbol_twitch_drop"/>
				<property name="min_distance" value="0"/>
				<property name="max_distance" value="-1"/>
				<property name="color" value="255,255,255,255"/>
			</map_settings>

			<compass_settings>
				<property name="sprite_name" value="ui_game_symbol_twitch_drop"/>
				<property name="min_distance" value="0"/>
				<property name="max_distance" value="500"/>
				<property name="max_scale_distance" value="1024"/>
				<property name="color" value="255,255,255,255"/>
				<property name="icon_clamped" value="false" />
			</compass_settings>

			<onscreen_settings>
				<property name="sprite_name" value="ui_game_symbol_twitch_drop"/>
				<property name="min_distance" value="0"/>
				<property name="max_distance" value="500"/>
				<property name="color" value="255,255,255,255"/>
				<property name="text_type" value="SpawnName"/>
			</onscreen_settings>
		</nav_object_class>
		
	</append>

</Config>