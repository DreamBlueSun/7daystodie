<configs>
<append xpath="/gameevents">
        <!-- 无限弹药 -->
	<action_sequence name="ZBS_InfiniteCorro">
		<action class="AddItems">
			<property name="added_items" value="thrownZBSAmmoCorrosiveLiquidInf" />
			<property name="added_item_counts" value="1" /></action>
	</action_sequence>
    <action_sequence name="ZBS_InfiniteGrenadeCorro">
		<action class="AddItems">
			<property name="added_items" value="thrownZBSGrenadeContactCorrosionInf" />
			<property name="added_item_counts" value="1" /></action>
	</action_sequence>
    
        <!-- 自爆 -->
	<action_sequence name="ZBS_BodyBombPlayer">
		<action class="ExplodeTarget">
			<property name="blast_power" value="0" />
			<property name="block_damage" value="0" />
			<property name="block_radius" value="1" />
			<property name="entity_damage" value="50" />
			<property name="entity_radius" value="1" />
            <property name="particle_index" value="7" />
		</action>
	</action_sequence>
	<action_sequence name="ZBS_BodyBombZombie">
		<action class="ExplodeTarget">
			<property name="blast_power" value="80" />
			<property name="block_damage" value="0" />
			<property name="block_radius" value="1" />
			<property name="entity_damage" value="250" />
			<property name="entity_radius" value="6" />
            <property name="particle_index" value="7" />
		</action>
	</action_sequence>
    <action_sequence name="ZBS_GluttonyBomb">
        <action class="ExplodeTarget">
			<property name="blast_power" value="60" />
			<property name="block_damage" value="0" />
			<property name="block_radius" value="1" />
			<property name="entity_damage" value="650" />
			<property name="entity_radius" value="4" />
            <property name="particle_index" value="7" />
		</action>
	</action_sequence>
    
	<action_sequence name="ZBS_HeavySmashExplosion">
		<action class="ExplodeTarget">
			<property name="blast_power" value="0" />
			<property name="block_damage" value="250" />
			<property name="block_radius" value="2" />
			<property name="entity_damage" value="150" />
			<property name="entity_radius" value="4" />
            <property name="particle_index" value="12" />
		</action>
	</action_sequence>
    
        <!-- 宿主驱使 -->
	<action_sequence name="ZBS_CorpseMKill">
        <decision class="If">
        <requirement class="NearbyEntities">
			<property name="max_distance" value="10" />
		</requirement>
		<action class="AddBuff">
			<property name="buff_name" value="buffZBSBasedCorpseMKillScreen"/></action>
		</decision>
	</action_sequence>
    
