<Marisa>

    <!-- 杰恩和雷克特挑战任务互换 -->
    <remove xpath="/challenges/challenge[@name='meetJen']"/>
    <insertAfter xpath="/challenges/challenge[@name='meetRekt']">
        <challenge name="meetJen" title_key="challengeMeetJen" icon="ui_game_symbol_map_trader" group="Traders"
                   short_description_key="challengeMeetJenShort" description_key="challengeMeetJenDesc"
                   reward_text_key="challenge_reward_500xp" reward_event="challenge_reward_500">
            <objective type="MeetTrader" trader_name="npcTraderJen"/>
        </challenge>
    </insertAfter>
    <remove xpath="/challenges/challenge[@name='meetRekt']"/>
    <insertAfter xpath="/challenges/challenge[@name='meetJen']">
        <challenge name="meetRekt" title_key="challengeMeetRekt" icon="ui_game_symbol_map_trader" group="Traders"
                   short_description_key="challengeMeetRektShort" description_key="challengeMeetRektDesc"
                   reward_text_key="challenge_reward_1000xp" reward_event="challenge_reward_1000">
            <objective type="MeetTrader" trader_name="npcTraderRekt"/>
        </challenge>
    </insertAfter>



    <!--** 基础新手任务 -->
    <set xpath="/challenges/challenge[@name='craftClothes']/objective[@type='Craft']/@item">IridescentArmorT0LeatherPrimitiveOutfit</set>

    <set xpath="/challenges/challenge[@name='killLumberjack']/objective[@type='Kill']/@entity_names">zombieLumberjack,zombieLumberjackFeral,zombieLumberjackRadiated,zombieLumberjackInfernal,zombieLumberjackCrystallization,zombieLumberjackBerserk</set>
    <set xpath="/challenges/challenge[@name='killSpider']/objective[@type='Kill']/@entity_names">zombieSpider,zombieSpiderFeral,zombieSpiderRadiated,zombieSpiderCharged,zombieSpiderInfernal,zombieSpiderCrystallization,zombieSpiderBerserk</set>
    <set xpath="/challenges/challenge[@name='killBigMama']/objective[@type='Kill']/@entity_names">zombieFemaleFat,zombieFemaleFatFeral,zombieFemaleFatRadiated,zombieFemaleFatInfernal,zombieFemaleFatCrystallization,zombieFemaleFatBerserk</set>
    <set xpath="/challenges/challenge[@name='killTourist']/objective[@type='Kill']/@entity_names">zombieFatHawaiian,zombieFatHawaiianFeral,zombieFatHawaiianRadiated,zombieFatHawaiianInfernal,zombieBowler,zombieBowlerFeral,zombieBowlerRadiated,zombieBowlerInfernal,zombieFatHawaiianCrystallization,zombieFatHawaiianBerserk,zombieBowlerCrystallization,zombieBowlerBerserk</set>
    <set xpath="/challenges/challenge[@name='killMutated']/objective[@type='Kill']/@entity_names">zombieMutated,zombieMutatedFeral,zombieMutatedRadiated,zombieMutatedCharged,zombieMutatedInfernal,zombieMutatedCrystallization,zombieMutatedBerserk</set>
    <set xpath="/challenges/challenge[@name='killCop']/objective[@type='Kill']/@entity_names">zombieFatCop,zombieFatCopFeral,zombieFatCopRadiated,zombieFatCopInfernal,zombieFatCopCrystallization,zombieFatCopBerserk</set>
    <set xpath="/challenges/challenge[@name='killWights']/objective[@type='Kill']/@entity_names">zombieWightFeral,zombieWightRadiated,zombieWightCharged,zombieWightInfernal,zombieWightCrystallization,zombieWightBerserk</set>
    <set xpath="/challenges/challenge[@name='killDemolitions']/objective[@type='Kill']/@entity_names">zombieDemolition,zombieDemolitionCrystallization,zombieDemolitionBerserk</set>

    <remove xpath="/challenges/challenge[@name='wearClothes']"/>
    <insertAfter xpath="/challenges/challenge[@name='craftClothes']">
        <challenge name="wearClothes" title_key="challengeWearClothes" icon="ui_game_symbol_challenge_basics_wear_clothing" group="Basics" hint="challengeWearClothesHint1" short_description_key="challengeWearClothesShort" description_key="challengeWearClothesDesc">
            <objective type="Craft" item="BundlePerkGrilledMeatStar"/>
        </challenge>
    </insertAfter>

    <!--** 定居 -->
    <remove xpath="/challenges/challenge[@name='placeDoor' or @name='placeStorageContainer' or @name='upgradeToCobblestone']"/>
    <insertAfter xpath="/challenges/challenge[@name='placeSpikeTraps']">
        <!--* 放置 水栽培养皿[蓝蘑菇] -->
        <challenge name="placeIridescentPlantMushroomsHealth" title_key="challengePlaceplaceIridescentPlantMushroomsHealth" icon="ui_game_symbol_harvest" group="Homesteading" short_description_key="challengePlaceplaceIridescentPlantMushroomsHealthShort" description_key="challengePlaceplaceIridescentPlantMushroomsHealthDesc">
            <objective type="BlockPlace" block="IridescentPlantHydroponicVerticalMushroomsHealth" count="1"/>
        </challenge>
        <!--* 放置 炼金收集器 -->
        <challenge name="placeMarisaCntDewCollector" title_key="challengePlaceMarisaCntDewCollector" icon="ui_game_symbol_mother_load" group="Homesteading" short_description_key="challengePlaceMarisaCntDewCollectorShort" description_key="challengePlaceMarisaCntDewCollectorDesc">
            <objective type="BlockPlace" block="cntDewCollectorScrapIron" count="1"/>
        </challenge>
        <!--* 放置 旗帜 -->
        <challenge name="placeMarisaBannerStation" title_key="challengePlaceMarisaBannerStation" icon="ui_game_symbol_adventure" group="Homesteading" short_description_key="challengePlaceMarisaBannerStationShort" description_key="challengePlaceMarisaBannerStationDesc">
            <objective type="BlockPlace" block="BannerStation" count="1"/>
        </challenge>
    </insertAfter>

    <!--** 进阶生存 -->
    <remove xpath="/challenges/challenge[@name='eatCharredMeat']"/>
    <insertAfter xpath="/challenges/challenge[@name='drinkWaterSource']">
        <!--* 放置 魔理沙的微波炉 -->
        <challenge name="placeMarisaMicrowaveOven" title_key="challengePlaceMarisaMicrowaveOven" icon="ui_game_symbol_cookware" group="AdvancedSurvival" short_description_key="challengePlaceMarisaMicrowaveOvenShort" description_key="challengePlaceMarisaMicrowaveOvenDesc" reward_text_key="challenge_reward_500xp" reward_event="challenge_reward_500">
            <objective type="BlockPlace" block="MarisaMicrowaveOven" count="1"/>
        </challenge>
    </insertAfter>



    <!--** 环境挑战任务优化 -->
    <remove xpath="/challenges/challenge[@name='burntSurvivalKillZombie']/objective[@type='Kill']"/>
    <remove xpath="/challenges/challenge[@name='desertSurvivalKillZombie']/objective[@type='Kill']"/>
    <remove xpath="/challenges/challenge[@name='snowSurvivalKillZombie']/objective[@type='Kill']"/>
    <remove xpath="/challenges/challenge[@name='wastelandSurvivalKillZombie']/objective[@type='Kill']"/>

</Marisa>